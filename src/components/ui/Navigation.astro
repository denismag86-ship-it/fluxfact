---
import { t, languages, getLocalizedPath, type Locale } from '../../i18n/translations';

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50" style="background: rgba(10,14,39,0.85); backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid #1F2847;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[#0A0E27] font-bold text-sm transition-shadow group-hover:shadow-glow-cyan" style="background: #00E5FF;">
          F
        </div>
        <span class="text-lg font-bold text-txt-primary tracking-tight">Flux<span style="color: #00E5FF">Fact</span></span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">
        <a href={getLocalizedPath('/', locale)}
           class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200", currentPath === '/' ? 'text-accent-cyan bg-accent-cyan/[0.08]' : 'text-txt-secondary hover:text-txt-primary hover:bg-white/[0.04]']}>
          {t(locale, 'nav.home')}
        </a>
        <a href={getLocalizedPath('/tools/', locale)}
           class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200", currentPath.startsWith('/tools') ? 'text-accent-cyan bg-accent-cyan/[0.08]' : 'text-txt-secondary hover:text-txt-primary hover:bg-white/[0.04]']}>
          {t(locale, 'nav.tools')}
        </a>

        <!-- Divider -->
        <div class="w-px h-5 mx-2" style="background: #1F2847;" />

        <!-- Language switcher -->
        <div class="relative" data-lang-switcher>
          <button class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm text-txt-secondary hover:text-txt-primary hover:bg-white/[0.04] transition-all duration-200"
                  aria-label={t(locale, 'nav.language')}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
            <span>{languages[locale]}</span>
            <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute right-0 mt-2 w-48 rounded-xl py-1.5 hidden"
               style="background: #141B3C; border: 1px solid #1F2847; box-shadow: 0 16px 48px rgba(0,0,0,0.5);"
               data-lang-dropdown>
            {Object.entries(languages).map(([code, name]) => (
              <a href={getLocalizedPath(currentPath, code as Locale)}
                 class:list={["block px-4 py-2 text-sm transition-all duration-150 hover:bg-white/[0.06]", code === locale ? 'font-medium' : '']}
                 style={code === locale ? 'color: #00E5FF' : 'color: #A0B0D0'}>
                {name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button class="md:hidden p-2 rounded-lg text-txt-secondary hover:text-txt-primary hover:bg-white/[0.06] transition-all" data-mobile-toggle aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden" style="background: rgba(10,14,39,0.95); backdrop-filter: blur(20px); border-top: 1px solid #1F2847;" data-mobile-menu>
    <div class="px-4 py-4 space-y-1">
      <a href={getLocalizedPath('/', locale)} class="block px-3 py-2.5 rounded-lg text-sm font-medium text-txt-secondary hover:text-txt-primary hover:bg-white/[0.06] transition-all">
        {t(locale, 'nav.home')}
      </a>
      <a href={getLocalizedPath('/tools/', locale)} class="block px-3 py-2.5 rounded-lg text-sm font-medium text-txt-secondary hover:text-txt-primary hover:bg-white/[0.06] transition-all">
        {t(locale, 'nav.tools')}
      </a>
      <div class="pt-3 mt-3" style="border-top: 1px solid #1F2847;">
        <p class="px-3 text-xs font-medium uppercase tracking-wide mb-2" style="color: #5B6B8A">{t(locale, 'nav.language')}</p>
        <div class="flex flex-wrap gap-1.5 px-3">
          {Object.entries(languages).map(([code, name]) => (
            <a href={getLocalizedPath(currentPath, code as Locale)}
               class:list={["px-3 py-1.5 text-xs rounded-lg transition-all duration-200",
                 code === locale
                   ? ''
                   : 'hover:bg-white/[0.04]']}
               style={code === locale ? 'color: #00E5FF; background: rgba(0,229,255,0.08); border: 1px solid rgba(0,229,255,0.2)' : 'color: #A0B0D0; border: 1px solid #1F2847'}>
              {name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  document.querySelectorAll('[data-lang-switcher]').forEach((el) => {
    const btn = el.querySelector('button');
    const dropdown = el.querySelector('[data-lang-dropdown]');
    btn?.addEventListener('click', () => dropdown?.classList.toggle('hidden'));
    document.addEventListener('click', (e) => {
      if (!el.contains(e.target as Node)) dropdown?.classList.add('hidden');
    });
  });

  const mobileToggle = document.querySelector('[data-mobile-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  mobileToggle?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
</script>
