---
import { t, languages, getLocalizedPath, type Locale } from '../../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const year = new Date().getFullYear().toString();
---

<footer class="border-t border-white/5 bg-slate-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm">
            F
          </div>
          <span class="text-lg font-bold text-white">Flux<span class="text-blue-400">Fact</span></span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed">
          {t(locale, 'site.description')}
        </p>
      </div>

      <!-- Popular Tools -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t(locale, 'footer.tools')}</h3>
        <ul class="space-y-2" id="footer-tools">
          <!-- Populated dynamically by orchestrator -->
        </ul>
      </div>

      <!-- Languages -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t(locale, 'footer.languages')}</h3>
        <ul class="space-y-2">
          {Object.entries(languages).map(([code, name]) => (
            <li>
              <a href={getLocalizedPath('/', code as Locale)}
                 class:list={["text-sm transition-colors hover:text-blue-400", code === locale ? 'text-blue-400' : 'text-slate-400']}>
                {name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t(locale, 'footer.about')}</h3>
        <ul class="space-y-2">
          <li><a href={getLocalizedPath('/about/', locale)} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">{t(locale, 'footer.about')}</a></li>
          <li><a href={getLocalizedPath('/privacy/', locale)} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">{t(locale, 'footer.privacy')}</a></li>
          <li><a href={getLocalizedPath('/terms/', locale)} class="text-sm text-slate-400 hover:text-blue-400 transition-colors">{t(locale, 'footer.terms')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/5 text-center">
      <p class="text-sm text-slate-500">{t(locale, 'footer.copyright', { year })}</p>
    </div>
  </div>
</footer>
