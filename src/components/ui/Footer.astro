---
import { t, languages, getLocalizedPath, type Locale } from '../../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const year = new Date().getFullYear().toString();
---

<footer style="background: #0A0E27; border-top: 1px solid #1F2847;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[#0A0E27] font-bold text-sm" style="background: #00E5FF;">
            F
          </div>
          <span class="text-lg font-bold text-txt-primary">Flux<span style="color: #00E5FF">Fact</span></span>
        </a>
        <p class="text-sm text-txt-secondary leading-relaxed">
          {t(locale, 'site.description')}
        </p>
      </div>

      <!-- Popular Tools -->
      <div>
        <h3 class="text-sm font-semibold text-txt-primary mb-4">{t(locale, 'footer.tools')}</h3>
        <ul class="space-y-2" id="footer-tools">
          <!-- Populated dynamically by orchestrator -->
        </ul>
      </div>

      <!-- Languages -->
      <div>
        <h3 class="text-sm font-semibold text-txt-primary mb-4">{t(locale, 'footer.languages')}</h3>
        <ul class="space-y-2">
          {Object.entries(languages).map(([code, name]) => (
            <li>
              <a href={getLocalizedPath('/', code as Locale)}
                 class="text-sm transition-colors"
                 style={code === locale ? 'color: #00E5FF' : 'color: #A0B0D0'}
                 onmouseover="this.style.color='#00E5FF'"
                 onmouseout={code === locale ? '' : "this.style.color='#A0B0D0'"}>
                {name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-sm font-semibold text-txt-primary mb-4">{t(locale, 'footer.about')}</h3>
        <ul class="space-y-2">
          <li><a href={getLocalizedPath('/about/', locale)} class="text-sm text-txt-secondary hover:text-accent-cyan transition-colors">{t(locale, 'footer.about')}</a></li>
          <li><a href={getLocalizedPath('/privacy/', locale)} class="text-sm text-txt-secondary hover:text-accent-cyan transition-colors">{t(locale, 'footer.privacy')}</a></li>
          <li><a href={getLocalizedPath('/terms/', locale)} class="text-sm text-txt-secondary hover:text-accent-cyan transition-colors">{t(locale, 'footer.terms')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 text-center" style="border-top: 1px solid #1F2847;">
      <p class="text-sm text-txt-muted">{t(locale, 'footer.copyright', { year })}</p>
    </div>
  </div>
</footer>
