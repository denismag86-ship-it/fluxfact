---
/**
 * HomePage — shared home page content for all locales.
 * Each locale page (index.astro, de/index.astro, etc.) wraps this component.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../ui/Navigation.astro';
import Footer from '../ui/Footer.astro';
import { t, getAlternateLocales, type Locale } from '../../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const categories = [
  { icon: '📊', nameKey: 'cat.finance', slug: 'finance' },
  { icon: '🏋️', nameKey: 'cat.health', slug: 'health' },
  { icon: '💻', nameKey: 'cat.tech', slug: 'tech' },
  { icon: '📐', nameKey: 'cat.math', slug: 'math' },
  { icon: '🌍', nameKey: 'cat.travel', slug: 'travel' },
  { icon: '🎮', nameKey: 'cat.fun', slug: 'fun' },
];

const categoryNames: Record<string, Record<string, string>> = {
  en: { finance: 'Finance', health: 'Health', tech: 'Tech', math: 'Science', travel: 'Travel', fun: 'Fun' },
  de: { finance: 'Finanzen', health: 'Gesundheit', tech: 'Technik', math: 'Wissenschaft', travel: 'Reise', fun: 'Spaß' },
  fr: { finance: 'Finance', health: 'Santé', tech: 'Tech', math: 'Science', travel: 'Voyage', fun: 'Divertissement' },
  es: { finance: 'Finanzas', health: 'Salud', tech: 'Tecnología', math: 'Ciencia', travel: 'Viajes', fun: 'Diversión' },
  'pt-br': { finance: 'Finanças', health: 'Saúde', tech: 'Tecnologia', math: 'Ciência', travel: 'Viagem', fun: 'Diversão' },
  ru: { finance: 'Финансы', health: 'Здоровье', tech: 'Технологии', math: 'Наука', travel: 'Путешествия', fun: 'Развлечения' },
  ja: { finance: '金融', health: '健康', tech: 'テクノロジー', math: '科学', travel: '旅行', fun: '楽しみ' },
};

function catName(slug: string): string {
  return categoryNames[locale]?.[slug] ?? categoryNames.en[slug] ?? slug;
}

const localePath = locale === 'en' ? '' : `/${locale}`;

// Tool cards data — localized
const tools = [
  {
    icon: '🏋️',
    gradient: 'from-emerald-500/20 to-cyan-500/20',
    borderColor: 'border-emerald-500/10',
    badge: 'free',
    titleKey: 'tool.bmi.title',
    descKey: 'tool.bmi.desc',
    tags: ['health', 'calculator'],
    href: `${localePath}/tools/bmi-calculator/`,
    live: true,
  },
  {
    icon: '💰',
    gradient: 'from-accent-blue/20 to-accent-purple/20',
    borderColor: 'border-accent-blue/10',
    badge: 'free',
    titleKey: 'tool.compound.title',
    descKey: 'tool.compound.desc',
    tags: ['finance', 'calculator'],
    href: `${localePath}/tools/compound-interest-calculator/`,
    live: true,
  },
  {
    icon: '🔒',
    gradient: 'from-accent-pink/20 to-accent-coral/20',
    borderColor: 'border-accent-pink/10',
    badge: 'free',
    titleKey: 'tool.password.title',
    descKey: 'tool.password.desc',
    tags: ['tech', 'checker'],
    href: `${localePath}/tools/password-strength-checker/`,
    live: true,
  },
];

// Tool titles/descriptions per locale
const toolStrings: Record<string, Record<string, string>> = {
  en: {
    'tool.bmi.title': 'BMI Calculator',
    'tool.bmi.desc': 'Calculate your Body Mass Index instantly. Visual scale with healthy range indicator.',
    'tool.compound.title': 'Compound Interest Calculator',
    'tool.compound.desc': 'See how your money grows over time with compound interest. Interactive chart included.',
    'tool.password.title': 'Password Strength Checker',
    'tool.password.desc': 'Check how strong your password is. Real-time analysis with improvement tips.',
  },
  de: {
    'tool.bmi.title': 'BMI-Rechner',
    'tool.bmi.desc': 'Berechnen Sie Ihren Body-Mass-Index sofort. Visuelle Skala mit Gesundheitsbereich.',
    'tool.compound.title': 'Zinseszins-Rechner',
    'tool.compound.desc': 'Sehen Sie, wie Ihr Geld mit Zinseszins wächst. Interaktives Diagramm inklusive.',
    'tool.password.title': 'Passwort-Stärke-Prüfer',
    'tool.password.desc': 'Prüfen Sie, wie stark Ihr Passwort ist. Echtzeit-Analyse mit Verbesserungstipps.',
  },
  fr: {
    'tool.bmi.title': 'Calculateur d\'IMC',
    'tool.bmi.desc': 'Calculez votre indice de masse corporelle instantanément. Échelle visuelle avec indicateur de santé.',
    'tool.compound.title': 'Calculateur d\'intérêts composés',
    'tool.compound.desc': 'Voyez comment votre argent croît avec les intérêts composés. Graphique interactif inclus.',
    'tool.password.title': 'Vérificateur de mot de passe',
    'tool.password.desc': 'Vérifiez la force de votre mot de passe. Analyse en temps réel avec conseils.',
  },
  es: {
    'tool.bmi.title': 'Calculadora de IMC',
    'tool.bmi.desc': 'Calcula tu índice de masa corporal al instante. Escala visual con rango saludable.',
    'tool.compound.title': 'Calculadora de interés compuesto',
    'tool.compound.desc': 'Mira cómo crece tu dinero con el interés compuesto. Gráfico interactivo incluido.',
    'tool.password.title': 'Verificador de contraseñas',
    'tool.password.desc': 'Verifica qué tan fuerte es tu contraseña. Análisis en tiempo real con consejos.',
  },
  'pt-br': {
    'tool.bmi.title': 'Calculadora de IMC',
    'tool.bmi.desc': 'Calcule seu índice de massa corporal instantaneamente. Escala visual com faixa saudável.',
    'tool.compound.title': 'Calculadora de juros compostos',
    'tool.compound.desc': 'Veja como seu dinheiro cresce com juros compostos. Gráfico interativo incluído.',
    'tool.password.title': 'Verificador de senhas',
    'tool.password.desc': 'Verifique a força da sua senha. Análise em tempo real com dicas de melhoria.',
  },
  ru: {
    'tool.bmi.title': 'Калькулятор ИМТ',
    'tool.bmi.desc': 'Рассчитайте индекс массы тела мгновенно. Визуальная шкала с индикатором нормы.',
    'tool.compound.title': 'Калькулятор сложных процентов',
    'tool.compound.desc': 'Посмотрите, как растут ваши деньги с учётом сложных процентов. Интерактивный график.',
    'tool.password.title': 'Проверка надёжности пароля',
    'tool.password.desc': 'Проверьте насколько надёжен ваш пароль. Анализ в реальном времени с рекомендациями.',
  },
  ja: {
    'tool.bmi.title': 'BMI計算機',
    'tool.bmi.desc': 'BMIを即座に計算。健康範囲インジケーター付きのビジュアルスケール。',
    'tool.compound.title': '複利計算機',
    'tool.compound.desc': '複利でお金がどう成長するか確認。インタラクティブチャート付き。',
    'tool.password.title': 'パスワード強度チェッカー',
    'tool.password.desc': 'パスワードの強度をチェック。リアルタイム分析と改善のヒント。',
  },
};

function ts(key: string): string {
  return toolStrings[locale]?.[key] ?? toolStrings.en[key] ?? key;
}
---

<BaseLayout
  title={`FluxFact — ${t(locale, 'site.description')}`}
  description={t(locale, 'site.description')}
  ogImage="/og/default.png"
  keywords={['free calculator', 'online tools', 'data visualization', 'interactive tools']}
  alternateLocales={getAlternateLocales('/')}
  locale={locale}
>
  <Navigation locale={locale} currentPath="/" />

  <main class="pt-16">
    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden min-h-[85vh] flex items-center">
      <div class="orb-blue w-[600px] h-[600px] -top-40 -left-40 animate-pulse-glow" />
      <div class="orb-purple w-[500px] h-[500px] top-20 right-[-10%] animate-pulse-glow" style="animation-delay: 1s" />
      <div class="orb-cyan w-[400px] h-[400px] bottom-0 left-1/3 animate-pulse-glow" style="animation-delay: 2s" />

      <div class="noise absolute inset-0" />

      <div class="absolute inset-0 opacity-[0.02]"
           style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;" />

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.06] border border-white/[0.08] mb-8 opacity-0 animate-fade-up">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
          <span class="text-sm text-txt-secondary">{t(locale, 'tool.free')}. {locale === 'ru' ? 'Без регистрации.' : locale === 'de' ? 'Keine Anmeldung.' : locale === 'ja' ? 'サインアップ不要。' : 'No sign-up required.'}</span>
        </div>

        <h1 class="heading-display mb-6 opacity-0 animate-fade-up" style="animation-delay: 100ms">
          {t(locale, 'home.hero.title').split('.').filter(Boolean).map((part, i, arr) => (
            i === 1
              ? <><span class="gradient-text">{part.trim()}.</span>{' '}</>
              : <>{part.trim()}.{i < arr.length - 1 ? ' ' : ''}</>
          ))}
        </h1>

        <p class="text-lg md:text-xl text-txt-secondary max-w-2xl mx-auto mb-12 leading-relaxed opacity-0 animate-fade-up" style="animation-delay: 200ms">
          {t(locale, 'home.hero.subtitle')}
        </p>

        <div class="flex flex-wrap justify-center gap-2 mt-8 opacity-0 animate-fade-up" style="animation-delay: 300ms">
          {categories.map((cat) => (
            <a href={`${localePath}/tools/${cat.slug}/`}
               class="px-4 py-2 rounded-full text-sm text-txt-secondary bg-white/[0.04] border border-white/[0.06] hover:bg-white/[0.08] hover:border-white/[0.12] transition-all duration-200">
              <span class="mr-1.5">{cat.icon}</span>{catName(cat.slug)}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TRENDING TOOLS ===== -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-center gap-3 mb-10">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse" />
        <h2 class="heading-section">{t(locale, 'home.trending')}</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card group">
            <div class="flex items-start justify-between mb-5">
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${tool.gradient} border ${tool.borderColor} flex items-center justify-center text-xl`}>
                {tool.icon}
              </div>
              <span class="badge-green">{t(locale, 'tool.free')}</span>
            </div>
            <h3 class="text-lg font-semibold text-txt-primary mb-2 group-hover:text-accent-blue transition-colors">
              {ts(tool.titleKey)}
            </h3>
            <p class="text-sm text-txt-secondary leading-relaxed">
              {ts(tool.descKey)}
            </p>
            <div class="mt-4 flex items-center gap-2 text-xs text-txt-muted">
              {tool.tags.map((tag) => (
                <span class="px-2 py-0.5 rounded bg-white/[0.04]">{catName(tag) || tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ===== CATEGORIES ===== -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="heading-section mb-10">{t(locale, 'home.categories')}</h2>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {categories.map((cat) => (
          <a href={`${localePath}/tools/${cat.slug}/`}
             class="glass-card-hover p-5 text-center group">
            <span class="text-3xl mb-3 block group-hover:scale-110 transition-transform">{cat.icon}</span>
            <span class="text-sm font-medium text-txt-primary">{catName(cat.slug)}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ===== VALUE PROPOSITION ===== -->
    <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="orb-blue w-[400px] h-[400px] top-0 left-1/2 -translate-x-1/2 opacity-50" />

      <div class="relative glass-card p-8 md:p-14">
        <div class="grid md:grid-cols-3 gap-10">
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-accent-blue/10 border border-accent-blue/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-txt-primary mb-2">
              {locale === 'ru' ? 'Мгновенные результаты' : locale === 'de' ? 'Sofortige Ergebnisse' : locale === 'ja' ? '即座の結果' : 'Instant Results'}
            </h3>
            <p class="text-sm text-txt-secondary leading-relaxed">
              {locale === 'ru' ? 'Все инструменты работают в браузере. Без регистрации, без ожидания.' : locale === 'de' ? 'Alle Tools laufen im Browser. Keine Anmeldung, kein Warten.' : locale === 'ja' ? 'すべてのツールはブラウザで動作。サインアップ不要。' : 'All tools run in your browser. No sign-up, no waiting. Just instant answers.'}
            </p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-accent-purple/10 border border-accent-purple/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-accent-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-txt-primary mb-2">
              {locale === 'ru' ? '7 языков' : locale === 'de' ? '7 Sprachen' : locale === 'ja' ? '7言語対応' : '7 Languages'}
            </h3>
            <p class="text-sm text-txt-secondary leading-relaxed">
              {locale === 'ru' ? 'Доступно на английском, немецком, французском, испанском, португальском, русском и японском.' : locale === 'de' ? 'Verfügbar auf Englisch, Deutsch, Französisch, Spanisch, Portugiesisch, Russisch und Japanisch.' : locale === 'ja' ? '英語、ドイツ語、フランス語、スペイン語、ポルトガル語、ロシア語、日本語で利用可能。' : 'Available in English, German, French, Spanish, Portuguese, Russian, and Japanese.'}
            </p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-accent-pink/10 border border-accent-pink/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-accent-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-txt-primary mb-2">
              {locale === 'ru' ? 'Делитесь везде' : locale === 'de' ? 'Überall teilen' : locale === 'ja' ? 'どこでもシェア' : 'Share Anywhere'}
            </h3>
            <p class="text-sm text-txt-secondary leading-relaxed">
              {locale === 'ru' ? 'Красивые карточки результатов. Один клик — и результат в соцсетях.' : locale === 'de' ? 'Schöne Ergebniskarten für jedes Ergebnis. Ein Klick zum Teilen.' : locale === 'ja' ? 'すべての結果に美しいシェアカード。ワンクリックでSNSにシェア。' : 'Beautiful share cards for every result. One click to share on any social network.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="relative overflow-hidden py-24">
      <div class="orb-purple w-[500px] h-[500px] top-0 right-0" />
      <div class="orb-blue w-[400px] h-[400px] bottom-0 left-0" />
      <div class="noise absolute inset-0" />

      <div class="relative z-10 text-center max-w-2xl mx-auto px-4">
        <h2 class="heading-section mb-4">
          {locale === 'ru' ? <>Все <span class="gradient-text">инструменты</span></> :
           locale === 'de' ? <>Alle <span class="gradient-text">Tools</span> entdecken</> :
           locale === 'ja' ? <>すべての<span class="gradient-text">ツール</span>を探索</> :
           <>Explore all <span class="gradient-text">tools</span></>}
        </h2>
        <p class="text-txt-secondary mb-8 leading-relaxed">
          {t(locale, 'site.description')}
        </p>
        <a href={`${localePath}/tools/`} class="btn-primary text-base px-8 py-4">
          {locale === 'ru' ? 'Все инструменты' : locale === 'de' ? 'Alle Tools ansehen' : locale === 'ja' ? 'すべてのツール' : 'Browse All Tools'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '50px' }
  );
  document.querySelectorAll('.tool-card, .glass-card-hover').forEach((el) => observer.observe(el));
</script>
