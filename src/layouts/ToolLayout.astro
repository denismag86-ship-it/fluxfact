---
/**
 * ToolLayout — interactive tool pages with SEO article below.
 */
import BaseLayout from './BaseLayout.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';
import ShareButtons from '../components/seo/ShareButtons.astro';
import { t, getAlternateLocales, type Locale } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  category: string;
  keywords?: string[];
  ogImage?: string;
  publishedDate: string;
  modifiedDate: string;
  toolName?: string;
  toolCategory?: string;
  toolDescription?: string;
  faq?: { question: string; answer: string }[];
  relatedTools?: { title: string; slug: string; description: string }[];
  shareText?: string;
  slug: string;
}

const {
  title,
  description,
  locale = 'en',
  category,
  keywords = [],
  ogImage,
  publishedDate,
  modifiedDate,
  toolName,
  toolCategory,
  toolDescription,
  faq = [],
  relatedTools = [],
  shareText,
  slug,
} = Astro.props;

const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();
const localePath = locale === 'en' ? '' : `/${locale}`;

const breadcrumbs = [
  { name: t(locale, 'nav.home'), url: `https://fluxfact.tech${localePath}/` },
  { name: t(locale, 'nav.tools'), url: `https://fluxfact.tech${localePath}/tools/` },
  { name: category, url: `https://fluxfact.tech${localePath}/tools/${category}/` },
  { name: title, url: currentUrl },
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType="article"
  keywords={keywords}
  locale={locale}
  alternateLocales={getAlternateLocales(`/tools/${slug}/`)}
  publishedDate={publishedDate}
  modifiedDate={modifiedDate}
  schemaType="WebApplication"
  toolName={toolName ?? title}
  toolCategory={toolCategory ?? category}
  toolDescription={toolDescription ?? description}
  faq={faq}
  breadcrumbs={breadcrumbs}
>
  <Navigation locale={locale} currentPath={`/tools/${slug}/`} />

  <main class="pt-16">
    <!-- Ambient background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="orb-cyan w-[500px] h-[500px] -top-60 -right-40 opacity-30" />
      <div class="orb-magenta w-[400px] h-[400px] top-1/2 -left-40 opacity-20" />
    </div>

    <!-- Breadcrumbs -->
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && (
              <svg class="w-3.5 h-3.5" style="color: #5B6B8A" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            )}
            {i === breadcrumbs.length - 1 ? (
              <span class="text-txt-secondary">{crumb.name}</span>
            ) : (
              <a href={crumb.url} class="text-txt-muted hover:text-accent-cyan transition-colors">{crumb.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Tool Hero -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="badge-green">{t(locale, 'tool.free')}</span>
          <span class="text-xs font-medium uppercase tracking-wide" style="color: #5B6B8A">{category}</span>
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-txt-primary mb-4" style="letter-spacing: -0.02em">{title}</h1>
        <p class="text-lg text-txt-secondary leading-relaxed">{description}</p>
      </div>
    </section>

    <!-- Interactive Tool -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="card p-6 md:p-10">
        <slot name="tool" />
      </div>
    </section>

    <!-- Share Buttons -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <ShareButtons
        url={currentUrl}
        title={shareText ?? title}
        description={description}
        locale={locale}
      />
    </section>

    <!-- Divider -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="h-px" style="background: linear-gradient(90deg, transparent, #1F2847, transparent)" />
    </div>

    <!-- Article Content -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <article class="prose-custom max-w-3xl mx-auto">
        <slot />
      </article>
    </section>

    <!-- FAQ Section -->
    {faq.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="max-w-3xl mx-auto">
          <h2 class="heading-section mb-8">{t(locale, 'tool.faq')}</h2>
          <div class="space-y-3">
            {faq.map((item, i) => (
              <details class="card group" open={i === 0}>
                <summary class="flex items-center justify-between cursor-pointer p-5 text-txt-primary font-medium hover:text-accent-cyan transition-colors">
                  <span>{item.question}</span>
                  <svg class="w-5 h-5 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" style="color: #5B6B8A" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-txt-secondary leading-relaxed pt-4" style="border-top: 1px solid #1F2847;">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Related Tools -->
    {relatedTools.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="heading-section mb-8">{t(locale, 'tool.related')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedTools.map((tool) => (
            <a href={`${localePath}/tools/${tool.slug}/`} class="tool-card">
              <h3 class="text-lg font-semibold text-txt-primary mb-2">{tool.title}</h3>
              <p class="text-sm text-txt-secondary">{tool.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer locale={locale} />
</BaseLayout>
